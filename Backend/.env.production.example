# Reference for the environment variables to set on the backend Vercel project.
# Do not commit real values — set these in the Vercel dashboard.

DJANGO_SETTINGS_MODULE=config.settings.prod
SECRET_KEY=set-a-long-random-string
DATABASE_URL=postgres://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
ALLOWED_HOSTS=.vercel.app
CRON_SECRET=set-a-long-random-string
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
