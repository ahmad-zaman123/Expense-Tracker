# Copy to .env and fill in real values. Never commit .env.

SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=*

# Local PostgreSQL for dev; Neon (serverless Postgres) URL in production.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/expense_tracker

# Shared secret that Vercel Cron sends to the internal detect-recurring endpoint.
CRON_SECRET=change-me-cron-secret

# Comma-separated frontend origins allowed to call the API (CORS).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Production-only (comma-separated), used by config.settings.prod
CSRF_TRUSTED_ORIGINS=https://*.vercel.app
